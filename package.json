{
  "name": "booklike",
  "version": "1.0.0",
  "description": "Chrome extension to read web articles like a book — paginated, typeset, distraction-free.",
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs --prod",
    "release": "node scripts/build-release.mjs",
    "lint": "eslint src"
  },
  "keywords": [
    "chrome-extension",
    "reader-mode",
    "web-reader",
    "readability",
    "reading"
  ],
  "type": "module",
  "author": "Markus Mayer",
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "chrome-types": "^0.1.414",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 110,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "fflate": "^0.8.2"
  }
}
